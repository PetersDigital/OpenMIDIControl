# This file is the single source of truth for beta/RC version numbering.
# Update BEFORE creating feature branches for the next version.
# Format: MAJOR.MINOR.PATCH

# The latest stable release available to users
CURRENT_STABLE_RELEASE_VERSION=0.2.1

# The next version being developed and tested
NEXT_PLANNED_VERSION=0.2.2
